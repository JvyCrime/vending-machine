<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient Border Background -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <gradient
                android:type="linear"
                android:angle="315"
                android:startColor="@color/anim_purple_400"
                android:centerColor="@color/anim_pink_400"
                android:endColor="@color/anim_blue_400" />
        </shape>
    </item>
    <!-- White Inner Content Area (creates the border effect) -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <solid android:color="@color/white" />
        </shape>
    </item>
</layer-list>