<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Category Title (Invisible - preserves spacing) -->
    <TextView
        android:id="@+id/category_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CATEGORY NAME"
        android:fontFamily="@font/bebas_neue"
        android:textSize="56sp"
        android:textColor="#1A1A1A"
        android:letterSpacing="0.05"
        android:textAllCaps="true"
        android:gravity="center"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="0dp" />

    <!-- Category Title Image Overlay -->
    <ImageView
        android:id="@+id/category_title_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="@id/category_title"
        app:layout_constraintBottom_toBottomOf="@id/category_title"
        app:layout_constraintStart_toStartOf="@id/category_title"
        app:layout_constraintEnd_toEndOf="@id/category_title" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/category_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginTop="0dp"
        app:layout_constraintTop_toBottomOf="@id/category_title"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Fade Overlay Left -->
    <View
        android:layout_width="80dp"
        android:layout_height="0dp"
        android:background="@drawable/gradient_fade_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/category_recycler"
        app:layout_constraintBottom_toBottomOf="@id/category_recycler"
        android:translationZ="10dp" />

    <!-- Fade Overlay Right -->
    <View
        android:layout_width="80dp"
        android:layout_height="0dp"
        android:background="@drawable/gradient_fade_right"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/category_recycler"
        app:layout_constraintBottom_toBottomOf="@id/category_recycler"
        android:translationZ="10dp" />

</androidx.constraintlayout.widget.ConstraintLayout>