<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- IDLE STATE -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_idle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/text_zb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/archivo_black"
            android:text="ZB"
            android:textColor="@color/black"
            android:textSize="120sp"
            android:shadowColor="@color/black"
            android:shadowDx="8"
            android:shadowDy="8"
            android:shadowRadius="0.1"
            app:layout_constraintBottom_toTopOf="@+id/card_container_idle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            android:layout_marginBottom="32dp" />

        <!-- Hard Shadow for Card -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_hard_shadow_black"
            android:translationX="8dp"
            android:translationY="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/card_container_idle"
            app:layout_constraintEnd_toEndOf="@+id/card_container_idle"
            app:layout_constraintStart_toStartOf="@+id/card_container_idle"
            app:layout_constraintTop_toTopOf="@+id/card_container_idle" />

        <LinearLayout
            android:id="@+id/card_container_idle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_idle_border_gradient"
            android:orientation="vertical"
            android:padding="48dp"
            app:layout_constraintBottom_toTopOf="@+id/badge_idle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/text_zb"
            app:layout_constraintWidth_percent="0.8"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="128dp"
                android:layout_height="128dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_credit_card"
                android:layout_marginBottom="24dp"
                app:tint="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/space_mono_bold"
                android:text="PLACE ID ON SCANNER"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Hard Shadow for Badge -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_badge_shadow_purple"
            android:translationX="6dp"
            android:translationY="6dp"
            app:layout_constraintBottom_toBottomOf="@+id/badge_idle"
            app:layout_constraintEnd_toEndOf="@+id/badge_idle"
            app:layout_constraintStart_toStartOf="@+id/badge_idle"
            app:layout_constraintTop_toTopOf="@+id/badge_idle" />

        <TextView
            android:id="@+id/badge_idle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_black"
            android:fontFamily="@font/space_mono"
            android:paddingHorizontal="32dp"
            android:paddingVertical="16dp"
            android:text="21+ VERIFICATION REQUIRED"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/card_container_idle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SCANNING STATE -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_scanning"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/text_scanning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/archivo_black"
            android:text="SCANNING"
            android:textColor="@color/black"
            android:textSize="80sp"
            android:shadowColor="@color/black"
            android:shadowDx="6"
            android:shadowDy="6"
            android:shadowRadius="0.1"
            app:layout_constraintBottom_toTopOf="@+id/card_container_scanning"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            android:layout_marginBottom="48dp" />

        <!-- Hard Shadow for Card -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_hard_shadow_black"
            android:alpha="0.3"
            android:translationX="10dp"
            android:translationY="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/card_container_scanning"
            app:layout_constraintEnd_toEndOf="@+id/card_container_scanning"
            app:layout_constraintStart_toStartOf="@+id/card_container_scanning"
            app:layout_constraintTop_toTopOf="@+id/card_container_scanning" />

        <!-- Scanning Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_container_scanning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_scanning_inner_gradient"
            app:layout_constraintBottom_toTopOf="@+id/progress_container"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/text_scanning"
            app:layout_constraintWidth_percent="0.8"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_margin="64dp"
                android:src="@drawable/ic_credit_card_thick"
                android:alpha="0.3"
                app:tint="@color/black"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Corner Accents -->
            <!-- Top Left -->
            <View
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:layout_marginStart="32dp"
                android:layout_marginTop="32dp"
                android:background="@color/black"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <View
                android:layout_width="4dp"
                android:layout_height="48dp"
                android:layout_marginStart="32dp"
                android:layout_marginTop="32dp"
                android:background="@color/black"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Top Right -->
            <View
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:layout_marginEnd="32dp"
                android:layout_marginTop="32dp"
                android:background="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <View
                android:layout_width="4dp"
                android:layout_height="48dp"
                android:layout_marginEnd="32dp"
                android:layout_marginTop="32dp"
                android:background="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Bottom Left -->
            <View
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="32dp"
                android:background="@color/black"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
            <View
                android:layout_width="4dp"
                android:layout_height="48dp"
                android:layout_marginStart="32dp"
                android:layout_marginBottom="32dp"
                android:background="@color/black"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Bottom Right -->
            <View
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:layout_marginEnd="32dp"
                android:layout_marginBottom="32dp"
                android:background="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
            <View
                android:layout_width="4dp"
                android:layout_height="48dp"
                android:layout_marginEnd="32dp"
                android:layout_marginBottom="32dp"
                android:background="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Scanning Line -->
            <View
                android:id="@+id/scanning_line"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="#99000000"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Progress Section -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_hard_shadow_black"
            android:translationX="6dp"
            android:translationY="6dp"
            app:layout_constraintBottom_toBottomOf="@+id/progress_container"
            app:layout_constraintEnd_toEndOf="@+id/progress_container"
            app:layout_constraintStart_toStartOf="@+id/progress_container"
            app:layout_constraintTop_toTopOf="@+id/progress_container" />

        <FrameLayout
            android:id="@+id/progress_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hard_shadow_black"
            android:padding="4dp"
            app:layout_constraintBottom_toTopOf="@+id/text_progress"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/card_container_scanning"
            app:layout_constraintWidth_percent="0.6">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_white_rounded_18dp"
                android:padding="4dp">
                
                <!-- Need a custom rounded background for white inner part -->
                <View
                     android:id="@+id/progress_bar"
                     android:layout_width="0dp"
                     android:layout_height="match_parent"
                     android:layout_weight="0"
                     android:background="@drawable/bg_progress_gradient" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/text_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/space_mono"
            android:text="0%"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:letterSpacing="0.1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/progress_container" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SUCCESS STATE -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_success"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:visibility="gone">

        <!-- Check Card -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_hard_shadow_black"
            android:translationX="12dp"
            android:translationY="12dp"
            app:layout_constraintBottom_toBottomOf="@+id/card_container_success"
            app:layout_constraintEnd_toEndOf="@+id/card_container_success"
            app:layout_constraintStart_toStartOf="@+id/card_container_success"
            app:layout_constraintTop_toTopOf="@+id/card_container_success" />

        <LinearLayout
            android:id="@+id/card_container_success"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_success_border_gradient"
            android:orientation="vertical"
            android:padding="48dp"
            app:layout_constraintBottom_toTopOf="@+id/text_verified"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:src="@drawable/ic_check_circle_thick"
                app:tint="@color/anim_green_500" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_verified"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/archivo_black"
            android:text="VERIFIED"
            android:textColor="@color/black"
            android:textSize="100sp"
            android:shadowColor="#6622C55E"
            android:shadowDx="8"
            android:shadowDy="8"
            android:shadowRadius="0.1"
            app:layout_constraintBottom_toTopOf="@+id/badge_success"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/card_container_success"
            android:layout_marginBottom="24dp" />

        <!-- Badge Shadow -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_badge_shadow_green"
            android:translationX="8dp"
            android:translationY="8dp"
            app:layout_constraintBottom_toBottomOf="@+id/badge_success"
            app:layout_constraintEnd_toEndOf="@+id/badge_success"
            app:layout_constraintStart_toStartOf="@+id/badge_success"
            app:layout_constraintTop_toTopOf="@+id/badge_success" />

        <TextView
            android:id="@+id/badge_success"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_black"
            android:fontFamily="@font/archivo_black"
            android:paddingHorizontal="48dp"
            android:paddingVertical="24dp"
            android:text="AGE CONFIRMED"
            android:textColor="@color/white"
            android:textSize="28sp"
            app:layout_constraintBottom_toTopOf="@+id/text_continue"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/text_verified"
            android:layout_marginBottom="32dp" />

        <TextView
            android:id="@+id/text_continue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/space_mono"
            android:text="CONTINUE TO CHECKOUT"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:alpha="0.6"
            android:letterSpacing="0.2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/badge_success" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>