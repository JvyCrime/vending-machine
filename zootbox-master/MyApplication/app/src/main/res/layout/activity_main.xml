<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Dark Mode Toggle -->
    <FrameLayout
        android:id="@+id/darkModeToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:background="@drawable/bg_white_rounded_18dp"
        android:backgroundTint="#1AFFFFFF"
        android:padding="12dp"
        android:elevation="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/orb_sun"
            app:tint="@color/white" />
    </FrameLayout>

    <!-- SECTION 3 (Bottom Layer) - POUCHES -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/section3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-96dp"
        android:paddingTop="96dp"
        android:background="@color/grid_card_3_light"
        app:layout_constraintTop_toBottomOf="@id/section2"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZOOTBOX"
            android:fontFamily="@font/oswald"
            android:textSize="140sp"
            android:textColor="#0DFFFFFF"
            android:textStyle="bold"
            android:includeFontPadding="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="5">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="48dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21+ ONLY"
                    android:fontFamily="@font/oswald"
                    android:textSize="14sp"
                    android:letterSpacing="0.1"
                    android:textColor="#0c4a6e"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="POUCHES"
                    android:fontFamily="@font/oswald"
                    android:textSize="48sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21+"
                    android:fontFamily="@font/oswald"
                    android:textSize="60sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_s3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BROWSE"
                    android:textColor="#0c4a6e"
                    android:backgroundTint="@color/white"
                    android:layout_marginTop="16dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:src="@drawable/img_category_zyns"
                android:padding="32dp"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SECTION 2 (Layer 2) - CIGARETTES -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/section2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-96dp"
        android:paddingTop="96dp"
        android:background="@drawable/bg_curve_bottom_left"
        android:backgroundTint="@color/grid_primary"
        android:elevation="20dp"
        app:layout_constraintTop_toBottomOf="@id/section1"
        app:layout_constraintHeight_percent="0.45">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZOOTBOX"
            android:fontFamily="@font/oswald"
            android:textSize="140sp"
            android:textColor="#0D000000"
            android:textStyle="bold"
            android:includeFontPadding="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="5">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="48dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21+ ONLY"
                    android:fontFamily="@font/oswald"
                    android:textSize="14sp"
                    android:letterSpacing="0.1"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CIGARETTES"
                    android:fontFamily="@font/oswald"
                    android:textSize="48sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21+"
                    android:fontFamily="@font/oswald"
                    android:textSize="60sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_s2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BROWSE"
                    android:textColor="@color/grid_primary"
                    android:backgroundTint="@color/white"
                    android:layout_marginTop="16dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:src="@drawable/img_category_cigs"
                android:padding="32dp"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SECTION 1 (Top Layer) - VAPES -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/section1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_curve_bottom_left"
        android:backgroundTint="@color/grid_card_1_light"
        android:elevation="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHeight_percent="0.33">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZOOTBOX"
            android:fontFamily="@font/oswald"
            android:textSize="140sp"
            android:textColor="#0DFFFFFF"
            android:textStyle="bold"
            android:includeFontPadding="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="5">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="48dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21+ ONLY"
                    android:fontFamily="@font/oswald"
                    android:textSize="14sp"
                    android:letterSpacing="0.1"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VAPES"
                    android:fontFamily="@font/oswald"
                    android:textSize="48sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21+"
                    android:fontFamily="@font/oswald"
                    android:textSize="60sp"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_s1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BROWSE"
                    android:textColor="@color/grid_card_1_light"
                    android:backgroundTint="@color/white"
                    android:layout_marginTop="16dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:src="@drawable/img_category_vapes"
                android:padding="32dp"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
