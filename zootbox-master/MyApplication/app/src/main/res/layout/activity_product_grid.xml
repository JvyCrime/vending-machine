<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".MainActivity">

    <!-- ================= BACKGROUND ================= -->
    <!-- Video Background Layer 1 -->
    <com.example.myapplication.FullScreenVideoView
        android:id="@+id/bg_video_view_1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="0dp"
        android:alpha="1.0"
        android:visibility="gone"
        android:layerType="hardware" />

    <!-- Video Background Layer 2 -->
    <com.example.myapplication.FullScreenVideoView
        android:id="@+id/bg_video_view_2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="0dp"
        android:alpha="0.0"
        android:visibility="gone"
        android:layerType="hardware" />
    
    
    <!-- ================= CONTENT ================= -->

    <!-- Product Grid (No Container) - Full Screen -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/product_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="220dp"
        android:paddingBottom="24dp"
        android:overScrollMode="never"
        android:background="@android:color/transparent" />

    <!-- Header Container with Gradient Fade -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_fade"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header: ZOOTBOX Stacked Title -->
        <include
            android:id="@+id/zootbox_title"
            layout="@layout/zootbox_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </FrameLayout>

    <!-- Back Button - positioned at left edge, on top of everything -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/backButton"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="4dp"
        android:text="←"
        android:textSize="28sp"
        android:textColor="#000000"
        android:gravity="center"
        android:elevation="20dp"
        android:translationZ="20dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        android:padding="0dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:cornerRadius="25dp"
        app:strokeColor="#000000"
        app:strokeWidth="2dp"
        app:backgroundTint="@android:color/transparent"
        app:rippleColor="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>