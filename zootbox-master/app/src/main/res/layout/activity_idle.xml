<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abs_coal">

    <!--
    ViewFlipper holds the 6 ad slides. Slides are inflated and added
    programmatically in IdleActivity.kt → inflateSlides().
    -->
    <ViewFlipper
        android:id="@+id/vf_ads"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Bottom overlay: dot indicators + tap-to-dismiss prompt.
         Sits on top of the ViewFlipper via FrameLayout stacking. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="56dp">

        <!-- Dot indicators — one dot per ad slide, active dot uses bg_dot_active. -->
        <LinearLayout
            android:id="@+id/dot_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center" />

        <!-- Tap-to-dismiss hint shown below the dots. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="TAP ANYWHERE TO SHOP"
            android:textColor="@color/abs_fog"
            android:textSize="13sp"
            android:letterSpacing="0.15"
            android:fontFamily="@font/archivo_black" />

    </LinearLayout>

</FrameLayout>
