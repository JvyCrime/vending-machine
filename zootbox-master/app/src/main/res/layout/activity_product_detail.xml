<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nested_scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abs_black"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Hero image area with wine radial glow -->
        <FrameLayout
            android:id="@+id/frame_hero"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHeight_percent="0.38">

            <!-- Wine radial glow behind image -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_abs_watercolor"
                android:importantForAccessibility="no" />

            <ImageView
                android:id="@+id/detail_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:padding="24dp" />

            <VideoView
                android:id="@+id/detail_video"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Back Button (floats over hero top-left) -->
        <!-- Hard shadow behind back button -->
        <View
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="34dp"
            android:layout_marginTop="34dp"
            android:background="@drawable/bg_hard_shadow_black"
            android:importantForAccessibility="no"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="32dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_back_button"
            android:src="@drawable/ic_arrow_back"
            android:tint="#0A0A0B"
            android:scaleType="center"
            android:elevation="8dp"
            android:contentDescription="Back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Warning Banner -->
        <LinearLayout
            android:id="@+id/card_warning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_abs_warning_banner"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/frame_hero">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_warning"
                android:tint="@color/warning_yellow"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/text_warning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WARNING: THIS PRODUCT CONTAINS NICOTINE. NICOTINE IS AN ADDICTIVE CHEMICAL."
                android:textColor="@color/abs_bone"
                android:textSize="10sp"
                android:fontFamily="@font/archivo_black"
                android:letterSpacing="0.10"
                android:textAllCaps="true" />
        </LinearLayout>

        <!-- Meta card: brand, name, price, rating, description -->
        <LinearLayout
            android:id="@+id/card_product_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/bg_abs_coal_card"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_warning">

            <!-- Brand · Category eyebrow -->
            <TextView
                android:id="@+id/text_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRAND · CATEGORY"
                android:textColor="@color/abs_ash"
                android:textSize="11sp"
                android:fontFamily="@font/space_mono"
                android:letterSpacing="0.20"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp" />

            <!-- Product Name -->
            <TextView
                android:id="@+id/detail_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRODUCT"
                android:textColor="@color/abs_bone"
                android:textSize="36sp"
                android:fontFamily="@font/archivo_black"
                android:layout_marginBottom="16dp" />

            <!-- Price + Stars row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/detail_price"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="$0.00"
                    android:textColor="@color/abs_bone"
                    android:textSize="40sp"
                    android:fontFamily="@font/archivo_black" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star_filled" android:tint="@color/star_filled" />
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star_filled" android:tint="@color/star_filled" />
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star_filled" android:tint="@color/star_filled" />
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star_filled" android:tint="@color/star_filled" />
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_star_outline" android:tint="@color/abs_ash" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.8 · 2,847"
                        android:textColor="@color/abs_ash"
                        android:textSize="11sp"
                        android:fontFamily="@font/space_mono"
                        android:layout_gravity="end"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/abs_fog"
                android:textSize="16sp"
                android:fontFamily="@font/inter"
                android:lineSpacingExtra="4dp" />

            <!-- Hidden views retained for compatibility -->
            <TextView android:id="@+id/detail_previous_price" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/text_product_snippet" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/text_review_count" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/text_flavor" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/text_nicotine_strength" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        </LinearLayout>

        <!-- Spec card -->
        <LinearLayout
            android:id="@+id/card_specifications"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/bg_abs_coal_card"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_product_info">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPECIFICATIONS"
                android:textColor="@color/abs_ash"
                android:textSize="11sp"
                android:fontFamily="@font/space_mono"
                android:letterSpacing="0.20"
                android:textAllCaps="true"
                android:layout_marginBottom="16dp" />

            <!-- Age Restriction row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Age restriction"
                    android:textColor="@color/abs_fog"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter" />

                <TextView
                    android:id="@+id/spec_nicotine_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21+"
                    android:textColor="@color/abs_bone"
                    android:textSize="15sp"
                    android:fontFamily="@font/archivo_black" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#29F5F1EA" />

            <!-- Category row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Category"
                    android:textColor="@color/abs_fog"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter" />

                <TextView
                    android:id="@+id/spec_pouches_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/abs_bone"
                    android:textSize="15sp"
                    android:fontFamily="@font/archivo_black" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#29F5F1EA" />

            <!-- Tobacco-free row -->
            <LinearLayout
                android:id="@+id/spec_tobacco_free"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tobacco-free"
                    android:textColor="@color/abs_fog"
                    android:textSize="15sp"
                    android:fontFamily="@font/inter" />

                <TextView
                    android:id="@+id/spec_flavor_profile_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/abs_bone"
                    android:textSize="15sp"
                    android:fontFamily="@font/archivo_black" />
            </LinearLayout>

            <!-- Hidden compat views -->
            <TextView android:id="@+id/spec_format_value" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        </LinearLayout>

        <!-- Quantity + Add to Cart section -->
        <LinearLayout
            android:id="@+id/card_quantity_cart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="32dp"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/bg_abs_coal_card"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_specifications">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUANTITY"
                android:textColor="@color/abs_ash"
                android:textSize="11sp"
                android:fontFamily="@font/space_mono"
                android:letterSpacing="0.20"
                android:textAllCaps="true"
                android:layout_marginBottom="16dp" />

            <!-- Qty controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btn_quantity_minus"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="−"
                    android:textColor="#0A0A0B"
                    android:textSize="26sp"
                    android:fontFamily="@font/archivo_black"
                    android:background="@drawable/bg_abs_bone_btn"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp" />

                <TextView
                    android:id="@+id/text_quantity"
                    android:layout_width="96dp"
                    android:layout_height="64dp"
                    android:text="1"
                    android:textColor="@color/abs_bone"
                    android:textSize="22sp"
                    android:fontFamily="@font/space_mono"
                    android:gravity="center"
                    android:background="@drawable/bg_abs_qty_display" />

                <Button
                    android:id="@+id/btn_quantity_plus"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="+"
                    android:textColor="#0A0A0B"
                    android:textSize="26sp"
                    android:fontFamily="@font/archivo_black"
                    android:background="@drawable/bg_abs_bone_btn"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- Add to Cart button -->
            <Button
                android:id="@+id/btn_add_to_cart"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:text="ADD TO CART"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="@font/archivo_black"
                android:letterSpacing="0.10"
                android:textAllCaps="true"
                android:background="@drawable/bg_abs_primary_btn"
                android:drawablePadding="12dp"
                android:gravity="center"
                android:elevation="0dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
