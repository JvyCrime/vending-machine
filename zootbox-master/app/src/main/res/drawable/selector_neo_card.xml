<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Pressed State: No Shadow (looks clicked) -->
    <item android:state_pressed="true">
        <layer-list>
            <!-- Main Surface shifted down/right to cover shadow -->
            <item android:left="4dp" android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/florida_gold"/>
                    <stroke android:width="3dp" android:color="@color/rich_black"/>
                    <corners android:radius="0dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Default State: Hard Shadow -->
    <item>
        <layer-list>
            <!-- Hard Shadow (Black Background) -->
            <item android:left="4dp" android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/rich_black"/>
                    <corners android:radius="0dp"/>
                </shape>
            </item>
            
            <!-- Main Surface (Offset Up/Left) -->
            <item android:right="4dp" android:bottom="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/rich_black"/> <!-- Dark card default -->
                    <stroke android:width="3dp" android:color="@color/teal_305"/>
                    <corners android:radius="0dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
