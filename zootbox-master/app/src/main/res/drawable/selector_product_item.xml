<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/deep_night_purple" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@color/florida_gold" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/asphalt_gray" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="@color/neon_pink" />
        </shape>
    </item>
</selector>
